# ─── Supabase (recommended) ───────────────────────────────────────────────────
# Use the "Direct connection" URL from:
#   Supabase dashboard → Project Settings → Database → Connection string → URI
#
# Format:
#   postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# ⚠️  Use port 5432 (direct connection), NOT port 6543 (PgBouncer/pooler).
#     The pooler's transaction mode is incompatible with the schema auto-apply
#     that runs on startup.
#
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── Local PostgreSQL (alternative) ───────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ubt_system

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret, e.g.: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_secret

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
